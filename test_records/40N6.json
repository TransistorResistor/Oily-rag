  "descriptions": [
    {
      "descrType": "Overview",
      "description": "The 40N6 is an ultra-long-range surface-to-air missile developed by Russia's Almaz-Antey for use with the S-400 Triumf air defense system. Introduced in service around 2017–2018, the 40N6 significantly extends the engagement envelope of the S-400, capable of engaging high-altitude aircraft, AWACS platforms, and cruise missiles at ranges exceeding 380 kilometers. The missile employs active radar homing in the terminal phase, allowing autonomous target engagement without continuous radar guidance from the launch platform.",
      "shortDescription": "Ultra-long-range surface-to-air missile with active radar terminal homing for the S-400 system.",
      "classification": "U"
    },
    {
      "descrType": "Design",
      "description": "The 40N6 features a streamlined cylindrical body optimized for extended-range flight at high altitude. Propulsion is provided by a solid-fuel rocket motor enabling transonic to supersonic cruise speed. The missile is equipped with semi-active or active radar homing guidance, allowing it to engage targets at extreme ranges. Its relatively large launch weight of approximately 1,893 kg and the sophisticated guidance system enable multi-role capability against fixed-wing aircraft, rotary-wing platforms, and airborne early-warning systems. The warhead is a directed-fragmentation type optimized for high-altitude interception.",
      "shortDescription": "Large solid-fuel SAM with active radar terminal homing and high-altitude engagement capability.",
      "classification": "U"
    }
  ],
