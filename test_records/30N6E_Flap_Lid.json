  "descriptions": [
    {
      "descrType": "Overview",
      "description": "The 30N6E Flap Lid is the engagement and fire-control radar of the S-300 air defense system, responsible for target tracking, missile guidance, and illumination of airborne threats. Operating with a detection range of approximately 200 kilometers, the 30N6E combines search, track, and engagement functions to provide continuous radar-guided missile engagement against high-speed and high-altitude aircraft. The radar operates in tandem with the 64N6E Big Bird surveillance radar and 96L6E Cheese Board supplementary radar to create a layered air defense architecture.",
      "shortDescription": "Fire-control/engagement radar for S-300 with ~200 km detection range and missile guidance capability.",
      "classification": "U"
    },
    {
      "descrType": "Design",
      "description": "The 30N6E employs a phased-array antenna mounted on a rotating turret, enabling 360-degree azimuth coverage and continuous target illumination during engagement. The radar uses frequency agility and electronic beam steering to counter jamming and electronic warfare threats. Mounted on a MAZ-7910 truck platform, the system is fully mobile and integrates with the S-300 command post and transporter-erector-launcher units through secure data links. The design supports simultaneous engagement of multiple targets through multi-channel missile guidance, enabling coordinated fire from different launch platforms within an air defense battalion.",
      "shortDescription": "Phased-array engagement radar with 360-degree coverage and multi-channel missile guidance capability.",
      "classification": "U"
    }
  ],
