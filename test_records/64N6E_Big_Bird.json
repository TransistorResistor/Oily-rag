  "descriptions": [
    {
      "descrType": "Overview",
      "description": "The 64N6E Big Bird is the primary long-range surveillance and acquisition radar of the S-300PMU series air defense system. Developed by Russian design bureaus, this radar provides target search and detection over vast distances, typically achieving detection ranges of approximately 300 kilometers against fighter-sized targets. The 64N6E serves as the system&#x27;s outer sentinel, identifying and tracking multiple airborne threats simultaneously to enable coordinated engagement by the fire-control radars and missile elements.",
      "shortDescription": "Long-range surveillance/acquisition radar for the S-300 system with ~300 km detection range.",
      "classification": "U"
    },
    {
      "descrType": "Design",
      "description": "The 64N6E employs a phased-array antenna design enabling rapid beam steering and simultaneous multi-target detection and tracking. The radar operates in the metric waveband with frequency-agile characteristics to reduce susceptibility to electronic countermeasures. The system is typically mounted on a MAZ-7910 truck platform for mobile deployment, incorporating command and control interfaces for network-centric warfare integration. The radar supports track-while-scan operating modes and provides target classification and altitude determination to support air defense engagement decisions.",
      "shortDescription": "Phased-array surveillance radar with metric-band operation and mobile truck-based deployment.",
      "classification": "U"
    }
  ],
