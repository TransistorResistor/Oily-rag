  "descriptions": [
    {
      "descrType": "Overview",
      "description": "The S-400 Triumf (NATO reporting name SA-21 Growler) is a long-range, all-altitude, all-weather air defense system developed and manufactured by Russia&#x27;s Almaz-Antey company. The system entered service with the Russian Air Force in 2005 and has since become Russia&#x27;s primary surface-to-air missile system. The S-400 combines search and acquisition radar, command post, power supply, and guided missiles on mobile or stationary platforms, capable of engaging aircraft, cruise missiles, and ballistic missiles.",
      "shortDescription": "Long-range Russian surface-to-air missile system with multi-target engagement capability.",
      "classification": "U"
    },
    {
      "descrType": "Design",
      "description": "The S-400 system consists of a command post, a 92N2A/92N2E radar, and transporter-erector-launcher (TEL) vehicles carrying missiles. The 92N2 radar provides search and track functions using a phased-array antenna. The system employs four missile types with different ranges and profiles: the 40N6 ultra-long-range missile, 48N6 long-range missile, 9M96 medium-range missile, and 9M96DM variant. The modular architecture allows rapid deployment, redeployment, and integration of updated components. Mobile versions use truck platforms enabling worldwide deployment.",
      "shortDescription": "Mobile/stationary air defense system with phased-array radar and four missile variants.",
      "classification": "U"
    }
  ],
