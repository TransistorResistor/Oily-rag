  "descriptions": [
    {
      "descrType": "Overview",
      "description": "The S-300 is a long-range, all-altitude, all-weather surface-to-air missile system developed by the Soviet Union&#x27;s NPO Almaz (Almaz-Antey). The system has been in continuous service since 1978 and remains one of the most widely deployed air defense systems globally. The S-300 combines search and acquisition radar, command post, power supply, and guided missiles on mobile or stationary platforms, capable of engaging aircraft, cruise missiles, and ballistic missiles. Later variants such as the S-300PMU-2 Favorit represent the apex of the S-300 family, sharing components with the more recent S-400 system.",
      "shortDescription": "Long-range Soviet/Russian surface-to-air missile system with integrated search and engagement radars.",
      "classification": "U"
    },
    {
      "descrType": "Design",
      "description": "The S-300 system employs the 48N6M and 9M96 missiles paired with dedicated search, acquisition, and engagement radars: the 64N6E Big Bird surveillance radar provides long-range target detection, the 30N6E Flap Lid radar handles engagement and missile guidance, and the 96L6E Cheese Board radar provides supplementary coverage. The modular architecture supports mobile deployment on MAZ-7910 8x8 truck platforms, enabling rapid redeployment and worldwide power projection. The system&#x27;s phased-array radars deliver simultaneous multi-target engagement capability against high-altitude and high-speed targets.",
      "shortDescription": "Mobile/stationary air defense system with 64N6E, 30N6E, and 96L6E radars and 48N6/9M96 missiles.",
      "classification": "U"
    }
  ],
